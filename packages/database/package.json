{
  "name": "@campus-chat/database",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "compiled": "./dist/src/index.js",
      "default": "./src/index.ts"
    },
    "./redis": {
      "types": "./src/redis.ts",
      "compiled": "./dist/src/redis.js",
      "default": "./src/redis.ts"
    },
    "./models": {
      "types": "./src/models/index.ts",
      "compiled": "./dist/src/models/index.js",
      "default": "./src/models/index.ts"
    },
    "./schema.ts": {
      "types": "./schema.ts",
      "compiled": "./dist/schema.js",
      "default": "./schema.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "compiled": "./dist/src/schema/index.js",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/fix-esm-imports.mjs dist",
    "check-types": "tsc --noEmit",
    "migrate": "sh ./scripts/migrate.sh",
    "migrate:docker": "sh ./scripts/migrate.docker.sh",
    "migrate:node": "node ./scripts/migrate.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@campus-chat/typescript-config": "workspace:*",
    "@types/pg": "^8.16.0",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  }
}
