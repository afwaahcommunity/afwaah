{
  "name": "@campus-chat/trpc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./server/index.ts",
      "compiled": "./dist/server/index.js",
      "default": "./server/index.ts"
    },
    "./client": {
      "types": "./client/index.ts",
      "compiled": "./dist/client/index.js",
      "default": "./client/index.ts"
    },
    "./context": {
      "types": "./server/context.ts",
      "compiled": "./dist/server/context.js",
      "default": "./server/context.ts"
    },
    "./openapi": {
      "types": "./server/openapi.ts",
      "compiled": "./dist/server/openapi.js",
      "default": "./server/openapi.ts"
    },
    "./router": {
      "types": "./server/router.ts",
      "compiled": "./dist/server/router.js",
      "default": "./server/router.ts"
    },
    "./schemas": {
      "types": "./server/schemas.ts",
      "compiled": "./dist/server/schemas.js",
      "default": "./server/schemas.ts"
    },
    "./server": {
      "types": "./server/index.ts",
      "compiled": "./dist/server/index.js",
      "default": "./server/index.ts"
    },
    "./server/context": {
      "types": "./server/context.ts",
      "compiled": "./dist/server/context.js",
      "default": "./server/context.ts"
    },
    "./server/openapi": {
      "types": "./server/openapi.ts",
      "compiled": "./dist/server/openapi.js",
      "default": "./server/openapi.ts"
    },
    "./server/router": {
      "types": "./server/router.ts",
      "compiled": "./dist/server/router.js",
      "default": "./server/router.ts"
    },
    "./server/schemas": {
      "types": "./server/schemas.ts",
      "compiled": "./dist/server/schemas.js",
      "default": "./server/schemas.ts"
    },
    "./server/trpc": {
      "types": "./server/trpc.ts",
      "compiled": "./dist/server/trpc.js",
      "default": "./server/trpc.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/fix-esm-imports.mjs dist",
    "check-types": "tsc --noEmit",
    "smoke:docker": "tsc -p tsconfig.smoke.json && node --loader ./scripts/ts-extension-loader.mjs .smoke-dist/scripts/smoke.js"
  },
  "dependencies": {
    "@campus-chat/database": "workspace:*",
    "@campus-chat/services": "workspace:*",
    "@trpc/client": "^11.1.0",
    "@trpc/server": "^11.1.0",
    "drizzle-orm": "^0.45.1",
    "superjson": "^2.2.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@campus-chat/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.16.0",
    "pg": "^8.16.3",
    "typescript": "5.9.2"
  }
}
