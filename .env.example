POSTGRES_PORT=5433
REDIS_PORT=6379

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/campus_chat
REDIS_URL=redis://localhost:6379

# Campus geofence defaults
CAMPUS_GEOFENCE_NAME=NIT Raipur Campus
CAMPUS_GEOFENCE_LAT=21.2497
CAMPUS_GEOFENCE_LNG=81.6022
CAMPUS_GEOFENCE_RADIUS_KM=5

# Optional one-time admin bootstrap values.
# Run: pnpm --filter @campus-chat/api admin:bootstrap
# ADMIN_BOOTSTRAP_DATABASE_URL=
ADMIN_BOOTSTRAP_EMAIL=admin@campus.local
# ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_DISPLAY_NAME=Campus Admin
ADMIN_BOOTSTRAP_ROLE=super_admin
ADMIN_BOOTSTRAP_MUST_CHANGE_PASSWORD=false
