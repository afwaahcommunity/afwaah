NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/campus_chat
POSTGRES_POOL_MAX=5
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLE_READY_CHECK=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SESSION_COOKIE_NAME=campus_session
ADMIN_COOKIE_NAME=campus_admin_session
ADMIN_SESSION_TTL_SECONDS=43200
TRUST_PROXY=true

# Optional one-time admin bootstrap values.
# Run: pnpm --filter @campus-chat/api admin:bootstrap
# ADMIN_BOOTSTRAP_DATABASE_URL=
ADMIN_BOOTSTRAP_EMAIL=admin@campus.local
# ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_DISPLAY_NAME=Campus Admin
ADMIN_BOOTSTRAP_ROLE=super_admin
ADMIN_BOOTSTRAP_MUST_CHANGE_PASSWORD=false
