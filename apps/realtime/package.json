{
  "name": "@campus-chat/realtime",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "dev": "node --watch --loader ts-node/esm --experimental-specifier-resolution=node src/index.ts",
    "smoke:docker": "node --loader ts-node/esm --experimental-specifier-resolution=node scripts/smoke.ts",
    "start": "node --loader ts-node/esm --experimental-specifier-resolution=node src/index.ts"
  },
  "dependencies": {
    "@campus-chat/database": "workspace:*",
    "@campus-chat/services": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.4.2",
    "pg": "^8.16.3",
    "socket.io": "^4.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@campus-chat/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.16.0",
    "ts-node": "^10.9.2",
    "typescript": "5.9.2"
  }
}
